# ============================================================================
# Elastic Observability Demo Platform — Environment Configuration
# ============================================================================
# Deployment credentials (Elastic URL, API key, Kibana URL, OTLP endpoint)
# are persisted in the app's SQLite database (data/deployments.db) when you
# deploy via the web UI. You do NOT need to set them here.
#
# This file is for optional app-level overrides only (notification configs,
# port, active scenario, etc.).  Copy to .env and fill in values as needed:
#   cp .env.example .env
# ============================================================================

# ── Auto-Deploy on Startup ────────────────────────────────────────────────────
# If KIBANA_URL and ELASTIC_API_KEY are set, the app will automatically deploy
# ACTIVE_SCENARIO on startup (skipping the manual UI setup step).
# ELASTIC_URL and OTLP_ENDPOINT are optional — both are auto-derived from
# KIBANA_URL if omitted (requires a standard Elastic Cloud URL with .kb. in it).
#KIBANA_URL=https://my-cluster.kb.us-west-1.aws.found.io:9243
#ELASTIC_API_KEY=your-api-key-here
#ELASTIC_URL=https://my-cluster.es.us-west-1.aws.found.io:9243
#OTLP_ENDPOINT=https://my-cluster.ingest.us-west-1.aws.found.io:443

# ── Kibana Proxy ──────────────────────────────────────────────────────────────
# If set, links in the landing page and slides will use this hostname instead
# of the actual Kibana URL. Useful when Kibana is served via a reverse proxy.
# API calls always use KIBANA_URL directly; this only affects user-facing links.
#KIBANA_PROXY=https://my-proxy.example.com

# ── App Settings ─────────────────────────────────────────────────────────────
# Scenario to deploy on startup. Available scenarios:
#   space       — NOVA-7 Space Mission
#   fanatics    — Fanatics Collectibles
#   financial   — Financial Trading Platform
#   healthcare  — Healthcare Systems
#   gaming      — Live Gaming Platform
#   banking     — Retail Banking Platform
#   gcp         — Google Cloud Network Operations
#ACTIVE_SCENARIO=space

# Public demo URL (used in slides page).
#DEMO_URL=/

# Bind address and port for the app server.
#APP_HOST=0.0.0.0
#APP_PORT=8080

# Seconds before an active fault channel auto-resolves (default: 3600 = 1 hour).
#CHANNEL_TIMEOUT=3600

# ── Guest / Read-Only Access ───────────────────────────────────────────────────
# If set, a read-only "viewer-custom" role and "guest" user are created during
# the "Configure platform settings" deployment step.  The guest user's password
# is set to this value.  Leave unset to skip role/user creation entirely.
#KIBANA_RO_PASSWORD=changeme
