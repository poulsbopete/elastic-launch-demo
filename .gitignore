# ============================================================
# NOVA-7 Elastic Launch Demo — .gitignore
# ============================================================

# ---------------------- Secrets / Env -----------------------
.env
.env.local
.env.*.local

# ---------------------- Python ------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# Virtual environments
venv/
.venv/
env/
ENV/

# Type checkers / linters
.mypy_cache/
.dmypy.json
.pytype/
.ruff_cache/
.pyre/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ---------------------- IDE / Editor ------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db


# ---------------------- OS ----------------------------------
*.pid
*.log
*.out
nohup.out

# ---------------------- Generated artifacts -----------------
# Dashboard NDJSON is generated by generate_exec_dashboard.py
elastic_config/dashboards/exec-dashboard.ndjson

# Temp files from curl/setup scripts
/tmp_*.json
/tmp_*.txt
*.tmp

# ---------------------- Runtime data -----------------------
data/

# ---------------------- Claude Code -------------------------
.claude/

# ---------------------- Obsidian -------------------------
.obsidian/
